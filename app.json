{
  "expo": {
    "name": "SnapClone",
    "slug": "SnapClone",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "snapclone",
    "userInterfaceStyle": "automatic",

    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SnapClone to access your camera",
          "microphonePermission": "Allow SnapClone to access your microphone"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow access to your photos",
          "savePhotosPermission": "Allow saving photos"
        }
      ]
    ],

    "android": {
      "package": "com.harshit.snapclone",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO"
      ]
    },

    "extra": {
      "eas": {
        "projectId": "78584900-13b5-4a4c-8e7f-b702c532cd73"
      }
    }
  }
}